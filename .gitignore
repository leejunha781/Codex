# 홈 디렉터리 전체 제외 — 아래 명시된 작업 폴더만 추적
/*
/.*
!/.gitattributes

# 추적할 폴더
!/.claude/
!/.codex/
!/.cursor/

# .cursor 안에서 추적할 항목
/.cursor/*
!/.cursor/memory/
!/.cursor/memory/**
!/.cursor/mcp/
!/.cursor/mcp/memory-sync/
!/.cursor/mcp/memory-sync/**
!/.cursor/mcp/memory-sync/package.json
!/.cursor/mcp/memory-sync/server.mjs
!/.cursor/mcp/memory-sync/README.md
/.cursor/mcp/memory-sync/node_modules/
!/.cursor/bin/
!/.cursor/bin/memory-sync.ps1
!/.cursor/bin/workspace.ps1
!/.cursor/hooks.json
!/.cursor/hooks/
!/.cursor/hooks/**
!/.cursor/mcp.json
!/.cursor/automations/
!/.cursor/automations/**

# .codex 안에서 추적할 폴더만 허용 (대용량 DB·캐시 제외)
/.codex/*
!/.codex/skills/
!/.codex/skills/**
!/.codex/automations/
!/.codex/automations/**
!/.codex/sessions/
!/.codex/sessions/**
!/.codex/archived_sessions/
!/.codex/archived_sessions/**
!/.codex/attachments/
!/.codex/attachments/**/*.json
!/.codex/attachments/**/*.txt
!/.codex/session_index.jsonl
!/.codex/external_agent_session_imports.json
!/.codex/process_manager/
!/.codex/process_manager/chat_processes.json
!/.codex/memory/
!/.codex/memory/**

# .claude 안 제외 항목
/.claude/cache/
/.claude/projects/C--Users-namma--claude/baeb5d66-046c-4315-b5b7-4f26997e0fc2/
/.claude/projects/C--Users-namma--claude/*/*
!/.claude/projects/C--Users-namma--claude/memory/
!/.claude/projects/C--Users-namma--claude/memory/**
!/.claude/projects/C--Users-namma--claude/*/subagents/
!/.claude/projects/C--Users-namma--claude/*/subagents/*.json
!/.claude/projects/C--Users-namma--claude/*/subagents/*.jsonl
!/.claude/projects/C--Users-namma--claude/*/tool-results/
!/.claude/projects/C--Users-namma--claude/*/tool-results/*.txt

# 공통 제외
**/.git/
*.png
*.jpg
*.jpeg
*.pdf
*.docx
*.pptx
*.zip
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.wal
*.shm
Thumbs.db
Desktop.ini
~$*
*.tmp
NTUSER*
ntuser*
